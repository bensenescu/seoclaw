ANTHROPIC_API_KEY=your-anthropic-api-key-here
EXA_API_KEY=your-exa-api-key-here

# Discord webhook for social listener alerts
# Get from: Discord server -> channel settings -> Integrations -> Webhooks
DISCORD_WEBHOOK_URL=your-discord-webhook-url-here

# Reddit OAuth (optional) -- enables Reddit as a social listening source
# Get from: reddit.com/prefs/apps -> create app -> script type
REDDIT_CLIENT_ID=your-reddit-client-id-here
REDDIT_CLIENT_SECRET=your-reddit-client-secret-here
