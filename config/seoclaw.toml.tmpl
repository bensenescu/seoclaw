# seoclaw configuration overlay  (THIS FILE IS OURS)
# ---------------------------------------------------------------------------
# `setup.sh` renders this template into  $ZEROCLAW_CONFIG_DIR/config.toml,
# substituting the __PLACEHOLDERS__ below. The program that READS this file is
# upstream ZeroClaw, unmodified and pinned in .zeroclaw-version — we don't fork
# it, we just hand it a config. Everything seoclaw-specific lives in this repo.
#
# Schema reference: https://docs.zeroclawlabs.ai/master/en/reference/config.html
# ---------------------------------------------------------------------------

# Config schema version. Required — without it the runtime treats this as a
# legacy config and drops the V3 `providers.models` section on migration.
schema_version = 3

# ── Provider: OpenAI Codex subscription (the only provider) ────────────────
# Codex sub auth is NOT an api_key. `setup.sh` runs
#   zeroclaw auth login --model-provider openai-codex
# which stores the Codex login on disk; `requires_openai_auth = true` tells the
# runtime to read that stored login instead of looking for a key here.
[providers.models.openai.coding]
model = "gpt-5.5"
wire_api = "responses"
requires_openai_auth = true

# ── Agent: the SEO claw ────────────────────────────────────────────────────
# `zeroclaw agent -a seo`  (or `seoclaw agent -a seo` via the bin/ wrapper)
[agents.seo]
model_provider  = "openai.coding"
risk_profile    = "supervised"
runtime_profile = "seo"          # enables extended thinking (see [runtime_profiles.seo])
skill_bundles   = ["seo"]
mcp_bundles     = ["seo"]

# ── Risk profile: supervised (medium-risk needs approval, high-risk blocked) ─
[risk_profiles.supervised]
level                            = "supervised"
workspace_only                   = true
require_approval_for_medium_risk = true
block_high_risk_commands         = true
# Subagents: auto-approve `spawn_subagent` so the agent can delegate research
# to ephemeral child agents without an approval prompt each time. (Subagents
# inherit this same profile, so their own tool calls are still gated.)
auto_approve = ["spawn_subagent"]
# To also stop prompts on OpenSEO lookups, add the tool names you use, e.g.:
#   auto_approve = ["spawn_subagent", "openseo__get_keyword_metrics", "openseo__research_keywords"]

# ── Skills: the OpenSEO skill bundle shipped IN THIS REPO ──────────────────
# Points straight at this checkout's skills/seo dir — edit a SKILL.md, restart
# the agent, and it's picked up. No copy/sync step.
[skill_bundles.seo]
directory = "__SKILLS_DIR__"

# ── Integration: OpenSEO MCP (the only SEO integration) ────────────────────
# OpenSEO authenticates in-conversation via its own `authenticate` tool the
# first time the agent calls it — no token is stored in this file.
[mcp_bundles.seo]
servers = ["openseo"]

[[mcp.servers]]
name = "openseo"
transport = "http"
url = "__OPENSEO_URL__"

# ── Runtime profile: extended thinking for deeper SEO reasoning ────────────
# Assigned to agents.seo via `runtime_profile = "seo"` above. high/max engage
# real reasoning budgets; native_thinking sends the provider's `thinking`
# parameter rather than just a prompt nudge. (Reasoning improves answers but
# stays hidden from chat output by design.)
[runtime_profiles.seo.thinking]
default_level   = "high"
native_thinking = true
# budget_tokens = { high = 10000, max = 50000 }   # optional; sensible defaults apply

# ── Heartbeats: periodic autonomous SEO checks ─────────────────────────────
# Only runs when seoclaw runs as a daemon/service (`seoclaw daemon` or
# `zeroclaw service install`) — NOT during interactive `agent -a seo`.
# Each tick reads the task list from:
#   <config_dir>/agents/seo/workspace/HEARTBEAT.md   (seeded by setup.sh)
# In two-phase mode the model first decides whether anything is due, then acts.
[heartbeat]
enabled          = true
agent            = "seo"
interval_minutes = 60
two_phase        = true
