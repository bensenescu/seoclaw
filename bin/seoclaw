#!/bin/sh
# seoclaw — light-touch branded wrapper around the stock `zeroclaw` binary.
#
# We do NOT rename or rebuild zeroclaw. This shim just pins the config/data dir
# to seoclaw's namespace and forwards every argument to upstream zeroclaw, so
# `seoclaw agent -a seo` works without the user remembering to export env vars.
set -eu

ZEROCLAW_CONFIG_DIR="${ZEROCLAW_CONFIG_DIR:-$HOME/.seoclaw}"
ZEROCLAW_DATA_DIR="${ZEROCLAW_DATA_DIR:-$ZEROCLAW_CONFIG_DIR/data}"
export ZEROCLAW_CONFIG_DIR ZEROCLAW_DATA_DIR

# For interactive `agent` runs, default to a persistent session file so a
# restart (needed to pick up config changes) doesn't drop the conversation.
# Only inject for the `agent` subcommand — other subcommands reject the flag —
# and only when the user didn't pass their own.
if [ "${1:-}" = "agent" ]; then
  case " $* " in
    *--session-state-file*) : ;;  # respect a user-supplied path
    *) set -- "$@" --session-state-file "$ZEROCLAW_CONFIG_DIR/seo-session.json" ;;
  esac
fi

exec zeroclaw "$@"
