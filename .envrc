# Makes `hermes` use THIS folder as its config home (config.yaml, SOUL.md,
# seo-skills/). With direnv installed, run `direnv allow` once and HERMES_HOME
# is set automatically whenever you're in this folder — no per-shell export.
# No direnv? Just run this line yourself from the repo root:  export HERMES_HOME="$PWD"
export HERMES_HOME="$PWD"
