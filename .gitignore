# Allowlist style: ignore EVERYTHING, then re-include only the distribution
# scaffold. This repo is a profile distribution — `hermes profile install`
# copies these files into ~/.hermes/profiles/seoclaw/. Ignoring everything else
# by default means no stray runtime/secret file can ever be committed.
/*

# Re-include the distribution scaffold (and nothing else).
!/skills/
!/distribution.yaml
!/config.yaml
!/SOUL.md
!/README.md
!/LICENSE
!/.gitignore

# ...but never the runtime files Hermes writes inside skills/ at use time
# (skill-usage tracking). These are per-user state, not distribution content.
.usage.json
.usage.json.lock
